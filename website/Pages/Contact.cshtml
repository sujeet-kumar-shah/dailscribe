@page
@model ContactModel
@{
    ViewData["Title"] = "Contact";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold section-title">Get in <span class="text-gradient">Touch</span></h1>
                <p class="text-secondary fs-5">Have a question, feedback, or need help? We'd love to hear from you.</p>
            </div>

            @if (Model.SuccessMessage != null)
            {
                <div class="alert alert-success rounded-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
                </div>
            }

            <form method="post" class="bg-light p-4 rounded-4 shadow-sm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Contact.Name" class="form-label fw-medium">Name</label>
                    <input asp-for="Contact.Name" class="form-control form-control-lg" placeholder="Your name" />
                    <span asp-validation-for="Contact.Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Contact.Email" class="form-label fw-medium">Email</label>
                    <input asp-for="Contact.Email" class="form-control form-control-lg" placeholder="you@example.com" />
                    <span asp-validation-for="Contact.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Contact.Message" class="form-label fw-medium">Message</label>
                    <textarea asp-for="Contact.Message" class="form-control form-control-lg" rows="5" placeholder="How can we help?"></textarea>
                    <span asp-validation-for="Contact.Message" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg rounded-pill w-100 py-3 fw-semibold">
                    <i class="bi bi-send me-2"></i>Send Message
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
