<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DayScribe</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Never forget what you learned today. DayScribe tracks your computer activity and generates AI-powered daily learning summaries.")" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-page="/Index">
                <i class="bi bi-journal-text me-2"></i>DayScribe
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Download">Download</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Blog/Index">Blog</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Contact">Contact</a></li>
                </ul>
                <a class="btn btn-primary rounded-pill px-4" asp-page="/Download">
                    <i class="bi bi-download me-1"></i>Download Free
                </a>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-light pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold"><i class="bi bi-journal-text me-2"></i>DayScribe</h5>
                    <p class="text-secondary">Never forget what you learned today. Your private, AI-powered daily companion.</p>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#" class="text-secondary" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-secondary" aria-label="GitHub"><i class="bi bi-github"></i></a>
                        <a href="#" class="text-secondary" aria-label="Discord"><i class="bi bi-discord"></i></a>
                        <a href="#" class="text-secondary" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase fw-bold">Product</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-page="/Features" class="text-secondary text-decoration-none">Features</a></li>
                        <li class="mb-1"><a asp-page="/Pricing" class="text-secondary text-decoration-none">Pricing</a></li>
                        <li class="mb-1"><a asp-page="/Download" class="text-secondary text-decoration-none">Download</a></li>
                        <li class="mb-1"><a asp-page="/Blog/Index" class="text-secondary text-decoration-none">Blog</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase fw-bold">Support</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-page="/Contact" class="text-secondary text-decoration-none">Contact</a></li>
                        <li class="mb-1"><a asp-page="/Privacy" class="text-secondary text-decoration-none">Privacy</a></li>
                        <li class="mb-1"><a asp-page="/Terms" class="text-secondary text-decoration-none">Terms</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold">Stay Updated</h6>
                    <p class="text-secondary small">Get the latest features and productivity tips.</p>
                    <form class="input-group" method="post" asp-page="/Index">
                        <input type="email" class="form-control form-control-sm" placeholder="Your email" required />
                        <button class="btn btn-primary btn-sm" type="submit">Subscribe</button>
                    </form>
                </div>
            </div>
            <hr class="border-secondary my-4" />
            <div class="text-center text-secondary small">
                &copy; @DateTime.Now.Year DayScribe. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
