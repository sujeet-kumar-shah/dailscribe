<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DayScribe</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Never forget what you learned today. DayScribe tracks your computer activity and generates AI-powered daily learning summaries.")" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-page="/Index">
                <i class="bi bi-journal-text me-2 text-primary"></i>DayScribe
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Download">Download</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Blog/Index">Blog</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Contact">Contact</a></li>
                </ul>
                <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-page="/Download">
                    <i class="bi bi-download me-1"></i>Download Free
                </a>
            </div>
        </div>
    </nav>

    <main style="padding-top: 72px;">
        @RenderBody()
    </main>

    <footer class="footer text-light pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold fs-4 mb-3">
                        <i class="bi bi-journal-text me-2 text-primary"></i>DayScribe
                    </h5>
                    <p class="text-secondary mb-3" style="color: var(--gray-400) !important;">Never forget what you learned today. Your private, AI-powered daily companion that runs entirely on your machine.</p>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#" class="text-secondary social-icon" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-secondary social-icon" aria-label="GitHub"><i class="bi bi-github"></i></a>
                        <a href="#" class="text-secondary social-icon" aria-label="Discord"><i class="bi bi-discord"></i></a>
                        <a href="#" class="text-secondary social-icon" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: var(--gray-300) !important;">Product</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-page="/Features" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Features</a></li>
                        <li class="mb-2"><a asp-page="/Pricing" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Pricing</a></li>
                        <li class="mb-2"><a asp-page="/Download" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Download</a></li>
                        <li class="mb-2"><a asp-page="/Blog/Index" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Blog</a></li>
                        <li class="mb-2"><a asp-page="/Privacy" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: var(--gray-300) !important;">Support</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-page="/Contact" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Contact</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Documentation</a></li>
                        <li class="mb-2"><a asp-page="/Terms" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Terms of Service</a></li>
                        <li class="mb-2"><a asp-page="/Privacy" class="text-secondary text-decoration-none" style="color: var(--gray-400) !important;">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: var(--gray-300) !important;">Stay Updated</h6>
                    <p class="small mb-3" style="color: var(--gray-400) !important;">Get the latest features, productivity tips, and updates delivered to your inbox.</p>
                    <form class="input-group" method="post" asp-page="/Index">
                        <input type="email" class="form-control bg-dark-800 border-secondary text-light" placeholder="your@email.com" required style="background: rgba(30,41,59,0.6);" />
                        <button class="btn btn-primary" type="submit">Subscribe</button>
                    </form>
                    <p class="mt-2 small" style="color: var(--gray-500) !important;">No spam. Unsubscribe anytime.</p>
                </div>
            </div>
            <hr class="my-4" style="border-color: rgba(148,163,184,0.15);" />
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="small" style="color: var(--gray-500) !important;">
                        &copy; @DateTime.Now.Year DayScribe. Built with <i class="bi bi-heart-fill text-danger"></i> for knowledge workers.
                    </span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <span class="small" style="color: var(--gray-500) !important;">
                        <i class="bi bi-shield-check me-1 text-success"></i>100% Local &middot;
                        <i class="bi bi-github me-1 ms-2"></i>MIT Licensed
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
