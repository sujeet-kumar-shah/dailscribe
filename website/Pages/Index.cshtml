@page
@{
    ViewData["Title"] = "DayScribe - Never Forget What You Learned Today";
    ViewData["Description"] = "DayScribe automatically tracks your computer activity and generates AI-powered daily digests. Privacy-first, local-only, no cloud dependency.";
}

<!-- Hero -->
<section class="hero text-light">
    <div class="hero-grid"></div>
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-glow-3"></div>
    <div class="container position-relative">
        <div class="row align-items-center g-5 py-5">
            <div class="col-lg-6">
                <div class="reveal-left">
                    <span class="badge bg-primary bg-opacity-10 text-primary-light mb-3 px-3 py-2 rounded-pill border border-primary border-opacity-25">
                        <i class="bi bi-shield-check me-1"></i>100% Local & Private
                    </span>
                    <h1 class="display-4 fw-bold mb-3 lh-1">Never forget what<br/><span class="text-gradient">you learned today.</span></h1>
                    <p class="lead mb-4 fs-5" style="color: var(--gray-400);">
                        DayScribe automatically tracks your apps, browser tabs, and articles. Each evening, get an AI-powered summary of everything you learned — without sending your data to the cloud.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-semibold" asp-page="/Download">
                            <i class="bi bi-download me-2"></i>Download Free
                        </a>
                        <a class="btn btn-outline-secondary btn-lg rounded-pill px-4 py-3 text-light" asp-page="/Features">
                            See Features <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                    <div class="d-flex align-items-center gap-4 mt-4">
                        <div class="d-flex align-items-center">
                            <div class="d-flex">
                                <i class="bi bi-windows me-1" style="color: var(--gray-400);"></i>
                                <i class="bi bi-apple mx-1" style="color: var(--gray-400);"></i>
                                <i class="bi bi-ubuntu ms-1" style="color: var(--gray-400);"></i>
                            </div>
                            <span class="ms-2 small" style="color: var(--gray-500);">Windows &middot; macOS &middot; Linux</span>
                        </div>
                        <span class="small" style="color: var(--gray-500);">
                            <i class="bi bi-github me-1"></i>Open Source
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="reveal-right text-center">
                    <div class="hero-stats-card p-4 text-start d-inline-block" style="max-width: 420px;">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="dot-pulse"></span>
                            <span class="small" style="color: var(--gray-400);">Tracking Active</span>
                            <span class="ms-auto text-secondary small">Today</span>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span style="color: var(--gray-300);">VS Code</span>
                                <span style="color: var(--gray-400);">4h 12m</span>
                            </div>
                            <div class="progress" style="height: 6px; background: rgba(148,163,184,0.15);">
                                <div class="progress-bar bg-primary" style="width: 42%; border-radius: 3px;"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span style="color: var(--gray-300);">Chrome</span>
                                <span style="color: var(--gray-400);">2h 30m</span>
                            </div>
                            <div class="progress" style="height: 6px; background: rgba(148,163,184,0.15);">
                                <div class="progress-bar" style="width: 25%; border-radius: 3px; background: var(--accent);"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span style="color: var(--gray-300);">Terminal</span>
                                <span style="color: var(--gray-400);">1h 15m</span>
                            </div>
                            <div class="progress" style="height: 6px; background: rgba(148,163,184,0.15);">
                                <div class="progress-bar" style="width: 12%; border-radius: 3px; background: var(--success);"></div>
                            </div>
                        </div>
                        <hr style="border-color: rgba(148,163,184,0.15);" />
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-star-fill text-warning mt-1"></i>
                            <div>
                                <p class="mb-0 small" style="color: var(--gray-300);">
                                    <strong style="color: var(--primary-light);">Today's Insight:</strong> You learned about event sourcing, Tailwind CSS v4, and distributed caching.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Highlight -->
<section class="py-5" id="features">
    <div class="container py-4">
        <div class="text-center mb-5 reveal">
            <h2 class="display-6 fw-bold section-title">Everything you need to <span class="text-gradient">remember more</span></h2>
            <p class="fs-5 mt-3" style="color: var(--gray-500);">DayScribe works quietly in the background so you can focus on what matters.</p>
        </div>
        <div class="row g-4 stagger-children">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card card h-100 border-0 p-4">
                    <div class="feature-icon bg-primary bg-opacity-10 text-primary mb-3">
                        <i class="bi bi-activity"></i>
                    </div>
                    <h5 class="fw-bold">Auto-Tracking</h5>
                    <p class="text-secondary small mb-0">Logs active windows, browser tabs, and time spent so you never wonder where your day went.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card card h-100 border-0 p-4">
                    <div class="feature-icon bg-info bg-opacity-10 text-info mb-3">
                        <i class="bi bi-robot"></i>
                    </div>
                    <h5 class="fw-bold">AI Summaries</h5>
                    <p class="text-secondary small mb-0">Daily digests powered by local LLMs (Ollama) or OpenAI. Get insights, not raw logs.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card card h-100 border-0 p-4">
                    <div class="feature-icon bg-success bg-opacity-10 text-success mb-3">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <h5 class="fw-bold">Local-First Privacy</h5>
                    <p class="text-secondary small mb-0">All data stays on your machine. Zero telemetry, zero cloud dependency. Your data is yours.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card card h-100 border-0 p-4">
                    <div class="feature-icon bg-warning bg-opacity-10 text-warning mb-3">
                        <i class="bi bi-chat-dots"></i>
                    </div>
                    <h5 class="fw-bold">Ask Anything</h5>
                    <p class="text-secondary small mb-0">Chat with your daily data. "What did I learn about Kubernetes?" — instant answer.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="section-light py-5">
    <div class="container py-4">
        <div class="text-center mb-5 reveal">
            <h2 class="display-6 fw-bold section-title">How it <span class="text-gradient">works</span></h2>
            <p class="fs-5 mt-3" style="color: var(--gray-500);">Three simple steps to start tracking your learning.</p>
        </div>
        <div class="row g-4 justify-content-center stagger-children">
            <div class="col-md-4">
                <div class="text-center step-card p-4">
                    <div class="step-number bg-primary text-white mx-auto mb-4 shadow-sm">1</div>
                    <h5 class="fw-bold">Install DayScribe</h5>
                    <p class="text-secondary">Download the desktop app for Windows, macOS, or Linux. One-click setup, no accounts required.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center step-card p-4">
                    <div class="step-number bg-primary text-white mx-auto mb-4 shadow-sm">2</div>
                    <h5 class="fw-bold">Go About Your Day</h5>
                    <p class="text-secondary">Work, browse, and learn as usual. DayScribe tracks active windows and browser tabs in the background.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center step-card p-4">
                    <div class="step-number bg-primary text-white mx-auto mb-4 shadow-sm">3</div>
                    <h5 class="fw-bold">Get Your Digest</h5>
                    <p class="text-secondary">Each evening, receive an AI-generated summary of what you learned — articles, code, tools, and more.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5 reveal">
            <h2 class="display-6 fw-bold section-title">Loved by <span class="text-gradient">knowledge workers</span></h2>
            <p class="fs-5 mt-3" style="color: var(--gray-500);">Here's what early users are saying about DayScribe.</p>
        </div>
        <div class="row g-4 stagger-children">
            <div class="col-md-4">
                <div class="testimonial-card card border-0 p-4 h-100">
                    <div class="d-flex mb-3">
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                    </div>
                    <p class="text-secondary mb-3">"DayScribe completely changed how I reflect on my workdays. The AI summaries are scarily accurate."</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-person text-primary fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Sarah Chen</h6>
                            <small class="text-secondary">Software Engineer</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card card border-0 p-4 h-100">
                    <div class="d-flex mb-3">
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                    </div>
                    <p class="text-secondary mb-3">"I was skeptical about yet another tracker, but the local-first approach won me over. And the Chrome extension is seamless."</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-person text-info fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Marcus Rivera</h6>
                            <small class="text-secondary">Product Designer</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card card border-0 p-4 h-100">
                    <div class="d-flex mb-3">
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <i class="bi bi-star-half text-warning"></i>
                    </div>
                    <p class="text-secondary mb-3">"The article summarization feature alone is worth it. I save hours every week revisiting key takeaways."</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-person text-success fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Priya Patel</h6>
                            <small class="text-secondary">PhD Researcher</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="section-light py-5">
    <div class="container py-4">
        <div class="row g-4 text-center stagger-children">
            <div class="col-md-3 col-6">
                <div class="p-4">
                    <div class="display-3 fw-bold text-gradient mb-1"><span class="counter" data-target="100">0</span>%</div>
                    <p class="text-secondary small">Local & Private</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-4">
                    <div class="display-3 fw-bold text-gradient mb-1"><span class="counter" data-target="0">0</span></div>
                    <p class="text-secondary small">Cloud Servers</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-4">
                    <div class="display-3 fw-bold text-gradient mb-1"><span class="counter" data-target="5">0</span>s</div>
                    <p class="text-secondary small">Tracking Interval</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-4">
                    <div class="display-3 fw-bold text-gradient mb-1">MIT</div>
                    <p class="text-secondary small">Open Source License</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="bg-dark text-light py-5 position-relative overflow-hidden">
    <div class="hero-glow-1" style="opacity: 0.3;"></div>
    <div class="container text-center py-4 position-relative">
        <h2 class="display-6 fw-bold mb-3 reveal">Start capturing your learning today</h2>
        <p class="lead mb-4 fs-5" style="color: var(--gray-400);">Free for individuals. No account. No cloud. No compromise.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap reveal">
            <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-semibold shadow-lg" asp-page="/Download">
                <i class="bi bi-download me-2"></i>Download DayScribe Free
            </a>
            <a class="btn btn-outline-secondary btn-lg rounded-pill px-4 py-3 text-light" asp-page="/Features">
                Explore Features
            </a>
        </div>
        <p class="mt-3 small" style="color: var(--gray-500);">
            <i class="bi bi-shield-check text-success me-1"></i>
            No account required. Your data never leaves your machine.
        </p>
    </div>
</section>
