</section>

<!-- CTA -->
<section class="bg-dark text-light py-5">
    <div class="container text-center py-4">
        <h2 class="display-6 fw-bold mb-3">Start capturing your learning today</h2>
        <p class="lead text-secondary mb-4 fs-5">Free for individuals. No account. No cloud. No compromise.</p>
        <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-semibold" asp-page="/Download">
            <i class="bi bi-download me-2"></i>Download DayScribe Free
        </a>
    </div>
</section>
