@page
@{
    ViewData["Title"] = "Pricing";
}

<div class="container py-5">
    <div class="text-center mb-5 reveal">
        <h1 class="display-5 fw-bold section-title">Simple, transparent <span class="text-gradient">pricing</span></h1>
        <p class="fs-5 mt-3" style="color: var(--gray-500);">Start free. Upgrade when you need more.</p>
    </div>

    <!-- Billing toggle -->
    <div class="d-flex justify-content-center align-items-center gap-3 mb-5 reveal">
        <span class="fw-medium" id="billingLabel" style="color: var(--gray-600);">Monthly</span>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="billingToggle" style="width: 3rem; height: 1.5rem; cursor: pointer; background-color: var(--primary); border-color: var(--primary);" />
        </div>
        <span class="fw-medium" style="color: var(--gray-600);">Annual <span class="badge bg-success ms-1">Save 20%</span></span>
    </div>

    <div class="row g-4 justify-content-center stagger-children">
        <!-- Free Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center">
                <div class="card-body d-flex flex-column">
                    <div>
                        <div class="mb-3">
                            <i class="bi bi-gem fs-1 text-secondary"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Free</h3>
                        <p class="text-secondary small">For individuals getting started</p>
                        <div class="price-amount my-4">
                            <span class="price-monthly">$0</span>
                            <span class="price-annual d-none">$0</span>
                            <span class="fs-6 fw-normal" style="color: var(--gray-500);">/month</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Basic activity tracking</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>5 AI digests per month</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>3 article summaries per week</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>7-day data history</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Chrome extension included</li>
                        <li class="mb-3" style="color: var(--gray-400);"><i class="bi bi-x-lg text-danger me-2"></i>AI Chat</li>
                    </ul>
                    <a asp-page="/Download" class="btn btn-outline-primary rounded-pill w-100 py-2 mt-auto">Get Started Free</a>
                </div>
            </div>
        </div>

        <!-- Pro Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center featured position-relative">
                <span class="position-absolute top-0 start-50 translate-middle badge bg-primary rounded-pill px-3 py-2 shadow">
                    Most Popular
                </span>
                <div class="card-body d-flex flex-column">
                    <div>
                        <div class="mb-3">
                            <i class="bi bi-stars fs-1" style="color: var(--primary);"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Pro</h3>
                        <p class="text-secondary small">For serious knowledge workers</p>
                        <div class="price-amount my-4">
                            <span class="price-monthly">$5</span>
                            <span class="price-annual d-none">$4</span>
                            <span class="fs-6 fw-normal" style="color: var(--gray-500);"><span class="billing-period">/month</span></span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Unlimited activity tracking</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Unlimited AI digests</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Unlimited article summaries</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Unlimited data history</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>AI Chat access</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Export data (CSV/JSON)</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Priority support</li>
                    </ul>
                    <a asp-page="/Download" class="btn btn-primary rounded-pill w-100 py-2 mt-auto shadow-sm">Subscribe Now</a>
                </div>
            </div>
        </div>

        <!-- Team Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center">
                <div class="card-body d-flex flex-column">
                    <div>
                        <div class="mb-3">
                            <i class="bi bi-building fs-1 text-secondary"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Team</h3>
                        <p class="text-secondary small">For organizations</p>
                        <div class="price-amount my-4">
                            <span class="price-monthly">$12</span>
                            <span class="price-annual d-none">$10</span>
                            <span class="fs-6 fw-normal" style="color: var(--gray-500);"><span class="billing-period">/user/month</span></span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Everything in Pro</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Team dashboard &amp; sharing</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Admin console &amp; reporting</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>SSO &amp; SAML</li>
                        <li class="mb-3"><i class="bi bi-check-lg text-success me-2"></i>Dedicated support</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary rounded-pill w-100 py-2 mt-auto">Contact Sales</a>
                    <p class="small mt-2 mb-0" style="color: var(--gray-400);">Coming Q4 2026</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Trust badges -->
    <div class="text-center mt-5 pt-3 reveal">
        <div class="d-flex justify-content-center gap-4 flex-wrap">
            <span class="small" style="color: var(--gray-500);">
                <i class="bi bi-shield-check text-success me-1"></i>Local-first privacy
            </span>
            <span class="small" style="color: var(--gray-500);">
                <i class="bi bi-credit-card me-1" style="color: var(--gray-400);"></i>No credit card needed
            </span>
            <span class="small" style="color: var(--gray-500);">
                <i class="bi bi-arrow-counterclockwise me-1" style="color: var(--gray-400);"></i>Cancel anytime
            </span>
            <span class="small" style="color: var(--gray-500);">
                <i class="bi bi-github me-1" style="color: var(--gray-400);"></i>Open source
            </span>
        </div>
    </div>
</div>
