@page
@{
    ViewData["Title"] = "Pricing";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold section-title">Simple, transparent <span class="text-gradient">pricing</span></h1>
        <p class="text-secondary fs-5">Start free. Upgrade when you need more.</p>
    </div>

    <!-- Billing toggle -->
    <div class="d-flex justify-content-center align-items-center gap-3 mb-5">
        <span class="text-secondary fw-medium" id="billingLabel">Monthly</span>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="billingToggle" style="width:3rem;height:1.5rem;cursor:pointer;" />
        </div>
        <span class="text-secondary fw-medium">Annual <span class="badge bg-success ms-1">Save 20%</span></span>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Free Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center">
                <div class="card-body">
                    <h3 class="fw-bold mb-1">Free</h3>
                    <p class="text-secondary small">For individuals getting started</p>
                    <div class="price-amount my-4">
                        <span class="price-monthly">$0</span>
                        <span class="price-annual d-none">$0</span>
                        <span class="fs-6 text-secondary fw-normal">/month</span>
                    </div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Basic activity tracking</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>5 AI digests per month</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>3 article summaries per week</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>7-day data history</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Chrome extension included</li>
                        <li class="text-secondary"><i class="bi bi-x-lg text-danger me-2"></i>AI Chat</li>
                    </ul>
                    <a asp-page="/Download" class="btn btn-outline-primary rounded-pill w-100 py-2">Get Started Free</a>
                </div>
            </div>
        </div>

        <!-- Pro Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center featured position-relative">
                <span class="position-absolute top-0 start-50 translate-middle badge bg-primary rounded-pill px-3 py-2">
                    Most Popular
                </span>
                <div class="card-body">
                    <h3 class="fw-bold mb-1">Pro</h3>
                    <p class="text-secondary small">For serious knowledge workers</p>
                    <div class="price-amount my-4">
                        <span class="price-monthly">$5</span>
                        <span class="price-annual d-none">$4</span>
                        <span class="fs-6 text-secondary fw-normal">/month</span>
                    </div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Unlimited activity tracking</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Unlimited AI digests</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Unlimited article summaries</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Unlimited data history</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>AI Chat access</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Export data (CSV/JSON)</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Priority support</li>
                    </ul>
                    <a asp-page="/Download" class="btn btn-primary rounded-pill w-100 py-2">Subscribe Now</a>
                </div>
            </div>
        </div>

        <!-- Team Plan -->
        <div class="col-lg-4 col-md-6">
            <div class="pricing-card card h-100 p-4 text-center opacity-50">
                <div class="card-body">
                    <h3 class="fw-bold mb-1">Team</h3>
                    <p class="text-secondary small">For organizations</p>
                    <div class="price-amount my-4">
                        <span class="price-monthly">--</span>
                        <span class="price-annual d-none">--</span>
                        <span class="fs-6 text-secondary fw-normal"></span>
                    </div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Everything in Pro</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Team dashboard &amp; sharing</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Admin console &amp; reporting</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>SSO &amp; SAML</li>
                        <li class="mb-2"><i class="bi bi-check-lg text-success me-2"></i>Dedicated support</li>
                    </ul>
                    <a href="#" class="btn btn-outline-secondary rounded-pill w-100 py-2 disabled">Coming Soon</a>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5 pt-3">
        <p class="text-secondary small">
            <i class="bi bi-shield-check text-success me-1"></i>
            All plans include local-first privacy. No cloud storage required.
        </p>
    </div>
</div>
