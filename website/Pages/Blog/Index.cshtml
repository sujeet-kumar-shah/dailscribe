@page
@model BlogIndexModel
@{
    ViewData["Title"] = "Blog";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold section-title">Productivity &amp; <span class="text-gradient">Learning</span></h1>
        <p class="text-secondary fs-5">Tips, insights, and updates from the DayScribe team.</p>
    </div>

    @if (!Model.Posts.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-text display-1 text-secondary"></i>
            <p class="text-secondary mt-3">No blog posts yet. Check back soon!</p>
        </div>
    }

    <div class="row g-4">
        @foreach (var post in Model.Posts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="blog-card card border-0 shadow-sm h-100">
                    @if (!string.IsNullOrEmpty(post.CoverImage))
                    {
                        <img src="@post.CoverImage" class="card-img-top" alt="@post.Title" onerror="this.style.display='none'" />
                    }
                    <div class="card-body p-4">
                        @if (post.Tags.Any())
                        {
                            <div class="mb-2">
                                @foreach (var tag in post.Tags)
                                {
                                    <span class="badge bg-light text-dark me-1">@tag</span>
                                }
                            </div>
                        }
                        <h5 class="fw-bold card-title">
                            <a asp-page="/Blog/Post" asp-route-slug="@post.Slug" class="text-decoration-none text-dark stretched-link">
                                @post.Title
                            </a>
                        </h5>
                        <p class="card-text text-secondary small">@post.Excerpt</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 px-4 pb-4 pt-0">
                        <div class="d-flex justify-content-between text-secondary small">
                            <span>@post.PublishedAt.ToString("MMM dd, yyyy")</span>
                            <span>@post.Author</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
