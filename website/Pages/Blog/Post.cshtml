@page "/blog/{slug}"
@model BlogPostModel
@{
    ViewData["Title"] = Model.Post?.Title ?? "Post Not Found";
}

@if (Model.Post == null)
{
    <div class="container py-5 text-center">
        <h2 class="fw-bold">Post not found</h2>
        <p class="text-secondary">The blog post you're looking for doesn't exist.</p>
        <a asp-page="/Blog/Index" class="btn btn-primary rounded-pill">&larr; Back to Blog</a>
    </div>
}
else
{
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <a asp-page="/Blog/Index" class="text-secondary text-decoration-none mb-3 d-inline-block">
                    <i class="bi bi-arrow-left me-1"></i>Back to Blog
                </a>

                @if (!string.IsNullOrEmpty(Model.Post.CoverImage))
                {
                    <img src="@Model.Post.CoverImage" class="img-fluid rounded-4 mb-4 w-100" alt="@Model.Post.Title" onerror="this.style.display='none'" />
                }

                <h1 class="display-6 fw-bold mb-3">@Model.Post.Title</h1>

                <div class="d-flex gap-3 text-secondary mb-4">
                    <span><i class="bi bi-person me-1"></i>@Model.Post.Author</span>
                    <span><i class="bi bi-calendar me-1"></i>@Model.Post.PublishedAt.ToString("MMMM dd, yyyy")</span>
                    @if (Model.Post.Tags.Any())
                    {
                        <span>
                            @foreach (var tag in Model.Post.Tags)
                            {
                                <span class="badge bg-light text-dark me-1">@tag</span>
                            }
                        </span>
                    }
                </div>

                <div class="blog-content">
                    @Html.Raw(Model.Post.Content)
                </div>
            </div>
        </div>
    </div>
}
