@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center" style="min-height: 60vh; display: flex; align-items: center; justify-content: center;">
    <div class="reveal">
        <div class="display-1 text-danger mb-4">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="display-5 fw-bold mb-3">Something went wrong</h1>
        <p class="fs-5 mb-4" style="color: var(--gray-500);">An error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p class="small mb-4" style="color: var(--gray-400);">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary rounded-pill px-4 py-2">
                <i class="bi bi-house me-1"></i>Go Home
            </a>
            <a href="/Contact" class="btn btn-outline-primary rounded-pill px-4 py-2">
                <i class="bi bi-envelope me-1"></i>Contact Support
            </a>
        </div>
    </div>
</div>
