@page "/"
@inject DailyDigestService DigestService
@inject IActivityTracker Tracker
@implements IDisposable

<div class="space-y-8 max-w-5xl mx-auto">
    <!-- Top Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Active App Time -->
        <div class="p-6 rounded-3xl bg-slate-900/40 border border-slate-800/80 shadow-xl backdrop-blur-md relative overflow-hidden group hover:border-slate-700/80 transition-all duration-300">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-brand-500/10 rounded-full blur-2xl group-hover:bg-brand-500/15 transition-all duration-300"></div>
            <div class="flex items-center justify-between mb-4">
                <span class="text-xs text-brand-400 font-bold uppercase tracking-wider">Active Workspace</span>
                <span class="p-2 rounded-xl bg-brand-500/10 text-brand-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </span>
            </div>
            <div class="text-3xl font-extrabold tracking-tight">@FormatDuration(Stats?.TotalAppTimeSecs ?? 0)</div>
            <p class="text-xs text-slate-400 mt-2">Active application focus time logged today</p>
        </div>

        <!-- Browser Reading Time -->
        <div class="p-6 rounded-3xl bg-slate-900/40 border border-slate-800/80 shadow-xl backdrop-blur-md relative overflow-hidden group hover:border-slate-700/80 transition-all duration-300">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/15 transition-all duration-300"></div>
            <div class="flex items-center justify-between mb-4">
                <span class="text-xs text-purple-400 font-bold uppercase tracking-wider">Web Reading</span>
                <span class="p-2 rounded-xl bg-purple-500/10 text-purple-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                </span>
            </div>
            <div class="text-3xl font-extrabold tracking-tight">@FormatDuration(Stats?.TotalBrowserTimeSecs ?? 0)</div>
            <p class="text-xs text-slate-400 mt-2">Active duration across browser tabs</p>
        </div>

        <!-- Summary / AI Digest Navigation Card -->
        <div class="p-6 rounded-3xl bg-slate-900/40 border border-slate-800/80 shadow-xl backdrop-blur-md relative overflow-hidden group hover:border-slate-700/80 transition-all duration-300 flex flex-col justify-between">
            <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-indigo-400 font-bold uppercase tracking-wider">Today's Synthesis</span>
            </div>
            <div>
                <a href="digest" class="w-full inline-flex items-center justify-center space-x-2 py-3 px-4 bg-gradient-to-r from-brand-600 to-indigo-600 hover:from-brand-500 hover:to-indigo-500 text-white text-sm font-semibold rounded-2xl shadow-lg shadow-brand-500/20 transition-all duration-200">
                    <span>What did I learn today?</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Visualizations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Top Apps Progress -->
        <div class="p-6 rounded-3xl bg-slate-900/30 border border-slate-800/60 shadow-xl backdrop-blur-md">
            <h3 class="text-base font-bold text-slate-200 mb-6 flex items-center space-x-2">
                <span>Top Applications Focus</span>
            </h3>
            
            <div class="space-y-4">
                @if (Stats == null || !Stats.TopApps.Any())
                {
                    <div class="text-center py-10 text-slate-500 text-sm">
                        No application tracking logged.
                    </div>
                }
                else
                {
                    @foreach (var app in Stats.TopApps.Take(5))
                    {
                        var percentage = Stats.TotalAppTimeSecs > 0 ? (app.DurationSecs / (double)Stats.TotalAppTimeSecs) * 100 : 0;
                        <div>
                            <div class="flex justify-between text-xs font-semibold text-slate-300 mb-1.5">
                                <span class="flex items-center space-x-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span>
                                    <span>@app.ProcessName</span>
                                </span>
                                <span class="text-slate-400">@FormatDuration(app.DurationSecs) (@Math.Round(percentage)%)</span>
                            </div>
                            <div class="w-full bg-slate-800/80 h-2.5 rounded-full overflow-hidden">
                                <div class="bg-gradient-to-r from-brand-500 to-indigo-500 h-full rounded-full transition-all duration-500" style="width: @percentage%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Top Browsed Domains -->
        <div class="p-6 rounded-3xl bg-slate-900/30 border border-slate-800/60 shadow-xl backdrop-blur-md">
            <h3 class="text-base font-bold text-slate-200 mb-6 flex items-center space-x-2">
                <span>Top Browsed Domains</span>
            </h3>

            <div class="space-y-4">
                @if (Stats == null || !Stats.TopDomains.Any())
                {
                    <div class="text-center py-10 text-slate-500 text-sm">
                        No browsing tracking logged yet.
                    </div>
                }
                else
                {
                    @foreach (var domain in Stats.TopDomains.Take(5))
                    {
                        var percentage = Stats.TotalBrowserTimeSecs > 0 ? (domain.DurationSecs / (double)Stats.TotalBrowserTimeSecs) * 100 : 0;
                        <div>
                            <div class="flex justify-between text-xs font-semibold text-slate-300 mb-1.5">
                                <span class="flex items-center space-x-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                                    <span class="truncate max-w-[200px]" title="@domain.Domain">@domain.Domain</span>
                                </span>
                                <span class="text-slate-400">@FormatDuration(domain.DurationSecs) (@Math.Round(percentage)%)</span>
                            </div>
                            <div class="w-full bg-slate-800/80 h-2.5 rounded-full overflow-hidden">
                                <div class="bg-gradient-to-r from-purple-500 to-pink-500 h-full rounded-full transition-all duration-500" style="width: @percentage%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- AI Chat Assistant Panel -->
    <div class="p-6 rounded-3xl bg-slate-900/40 border border-slate-800/80 shadow-2xl backdrop-blur-md flex flex-col h-[400px]">
        <h3 class="text-sm font-bold text-slate-300 mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            <span>Ask DayScribe about your day</span>
        </h3>

        <!-- Chat history area -->
        <div class="flex-1 overflow-y-auto space-y-4 mb-4 pr-2 scrollbar-thin">
            @if (!ChatMessages.Any())
            {
                <div class="flex flex-col items-center justify-center h-full text-slate-500 text-xs text-center space-y-2">
                    <p>Ask something like: <br/><em>"Which apps did I focus on the most?"</em> or <em>"Did I read anything about programming today?"</em></p>
                </div>
            }
            else
            {
                @foreach (var msg in ChatMessages)
                {
                    <div class="flex flex-col @(msg.Sender == "User" ? "items-end" : "items-start")">
                        <div class="max-w-[80%] rounded-2xl px-4 py-2.5 text-sm shadow-md @(msg.Sender == "User" ? "bg-brand-600 text-white rounded-br-none" : "bg-slate-800/80 text-slate-100 border border-slate-800 rounded-bl-none")">
                            @msg.Content
                        </div>
                        <span class="text-[10px] text-slate-500 mt-1 px-1">@msg.Timestamp.ToString("t")</span>
                    </div>
                }
            }

            @if (IsThinking)
            {
                <div class="flex items-center space-x-2 text-xs text-slate-400 bg-slate-850 p-3 rounded-2xl max-w-[200px] border border-slate-800">
                    <span class="flex h-2 w-2 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
                    </span>
                    <span>DayScribe is analyzing...</span>
                </div>
            }
        </div>

        <!-- Chat Input Bar -->
        <form @submit:preventDefault="SendMessage" class="flex space-x-3 items-center">
            <input @bind="ChatInput" type="text" placeholder="Ask a question..." disabled="@IsThinking" class="flex-1 px-4 py-3 rounded-2xl bg-slate-950/80 border border-slate-800/80 text-sm focus:outline-none focus:border-brand-500/80 focus:ring-1 focus:ring-brand-500/30 text-slate-100 disabled:opacity-55 transition" />
            <button type="submit" disabled="@(IsThinking || string.IsNullOrWhiteSpace(ChatInput))" class="px-5 py-3 rounded-2xl bg-brand-600 hover:bg-brand-500 transition-colors text-white font-semibold text-sm disabled:opacity-40 shadow-lg shadow-brand-600/25">
                Send
            </button>
        </form>
    </div>
</div>

@code {
    private TodayStats? Stats;
    private List<ChatMessage> ChatMessages = [];
    private string ChatInput = "";
    private bool IsThinking = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
        Tracker.OnActivityLogged += HandleActivityLogged;
    }

    private async Task LoadStatsAsync()
    {
        Stats = await DigestService.GetTodayStatsAsync();
    }

    private void HandleActivityLogged(string app, string title)
    {
        InvokeAsync(async () =>
        {
            await LoadStatsAsync();
            StateHasChanged();
        });
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(ChatInput)) return;

        var userQuery = ChatInput;
        ChatInput = "";

        ChatMessages.Add(new ChatMessage
        {
            Sender = "User",
            Content = userQuery
        });

        IsThinking = true;
        StateHasChanged();

        try
        {
            var answer = await DigestService.AskQuestionAsync(userQuery);
            ChatMessages.Add(new ChatMessage
            {
                Sender = "DayScribe",
                Content = answer
            });
        }
        catch (Exception ex)
        {
            ChatMessages.Add(new ChatMessage
            {
                Sender = "DayScribe",
                Content = $"Sorry, something went wrong: {ex.Message}"
            });
        }
        finally
        {
            IsThinking = false;
            StateHasChanged();
        }
    }

    private static string FormatDuration(int seconds)
    {
        if (seconds < 60) return $"{seconds}s";
        var minutes = seconds / 60;
        if (minutes < 60) return $"{minutes}m {seconds % 60}s";
        var hours = minutes / 60;
        return $"{hours}h {minutes % 60}m";
    }

    public void Dispose()
    {
        Tracker.OnActivityLogged -= HandleActivityLogged;
    }

    public class ChatMessage
    {
        public string Sender { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; } = DateTime.Now;
    }
}
